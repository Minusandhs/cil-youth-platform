# ================================================================
# CIL Youth Development Platform — Environment Variables Template
# Copy this file to .env and fill in real values before deploying.
# NEVER commit .env to version control.
# ================================================================

# ── Database ─────────────────────────────────────────────────────
POSTGRES_DB=cil_platform
POSTGRES_USER=cil_admin
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# ── Backend ──────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000
DATABASE_URL=postgres://cil_admin:CHANGE_THIS_STRONG_PASSWORD@db:5432/cil_platform

# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING
JWT_EXPIRES_IN=8h

# ── CORS ─────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Example: https://cil.yourdomain.com
CORS_ORIGIN=http://localhost:3000

# ── Frontend ─────────────────────────────────────────────────────
VITE_API_URL=http://localhost:5000
