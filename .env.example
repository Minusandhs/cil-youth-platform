# ================================================================
# CIL Youth Development Platform — Environment Variables Template
# Copy this file to .env and fill in real values before deploying.
# NEVER commit .env to version control.
# ================================================================

# ── Database ─────────────────────────────────────────────────────
POSTGRES_DB=cil_platform
POSTGRES_USER=cil_admin
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# ── Backend ──────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000
DATABASE_URL=postgres://cil_admin:CHANGE_THIS_STRONG_PASSWORD@db:5432/cil_platform

# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING
JWT_EXPIRES_IN=8h

# ── CORS ─────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGIN=https://cilyouth.org

# ── Frontend ─────────────────────────────────────────────────────
# In production nginx proxies /api/ — use the domain with no port.
VITE_API_URL=https://cilyouth.org

# ── Email (Amazon SES) ───────────────────────────────────────────
EMAIL_FROM=notifications@cilyouth.org
AWS_REGION=eu-north-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
